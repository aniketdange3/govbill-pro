rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Invoices collection
    match /invoices/{invoiceId} {
      allow list: if isSignedIn() && resource.data.createdBy == request.auth.uid;
      allow get: if isSignedIn() && resource.data.createdBy == request.auth.uid;
      
      allow create: if isSignedIn() 
        && isValidId(invoiceId)
        && incoming().createdBy == request.auth.uid
        && incoming().totalAmount is number
        && incoming().items is list
        && incoming().invoiceNo is string
        && incoming().invoiceDate is string;

      allow update: if isSignedIn()
        && existing().createdBy == request.auth.uid
        && incoming().createdBy == request.auth.uid
        && (
          // Allow changing status
          incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])
          || 
          // Allow editing draft invoices
          (existing().status == 'draft' && incoming().status == 'draft')
        );

      allow delete: if isSignedIn()
        && resource.data.createdBy == request.auth.uid
        && resource.data.status == 'draft';
    }

    // Clients collection
    match /clients/{clientId} {
      allow list: if isSignedIn() && resource.data.createdBy == request.auth.uid;
      allow get: if isSignedIn() && resource.data.createdBy == request.auth.uid;
      allow create: if isSignedIn() 
        && isValidId(clientId)
        && incoming().createdBy == request.auth.uid
        && incoming().name is string;
      allow update: if isSignedIn() && existing().createdBy == request.auth.uid;
      allow delete: if isSignedIn() && existing().createdBy == request.auth.uid;
    }

    // Settings / Company Profile
    match /settings/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }

    // Companies collection
    match /companies/{companyId} {
      allow list: if isSignedIn() && resource.data.createdBy == request.auth.uid;
      allow get: if isSignedIn() && resource.data.createdBy == request.auth.uid;
      allow create: if isSignedIn() 
        && isValidId(companyId)
        && incoming().createdBy == request.auth.uid
        && incoming().name is string;
      allow update: if isSignedIn() && existing().createdBy == request.auth.uid;
      allow delete: if isSignedIn() && existing().createdBy == request.auth.uid;
    }
  }
}
